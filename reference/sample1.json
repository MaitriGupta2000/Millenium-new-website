  "product_card_schema": {
    "image": "string (product photo)",
    "name": "string (product name)",
    "type": "string (specific variant/category label)",
    "price": "string",
    "features": ["array of short bullet strings (2-3 items)"],
    "primary_action": {
      "label": "View Details",
      "target": "detail_page (internal route)"
    },
    "secondary_action": {
      "label": "Buy on Amazon",
      "target": "amazon_link (external, opens new tab)"
    }
  },

  "product_detail_page_schema": {
    "route_pattern": "/products/{product_id}",
    "sections": [
      {
        "block": "gallery",
        "content": "array of product images, multiple angles"
      },
      {
        "block": "title_block",
        "content": {
          "name": "string",
          "type": "string",
          "price": "string",
          "short_tagline": "string"
        }
      },
      {
        "block": "full_description",
        "content": "long-form paragraph describing the product"
      },
      {
        "block": "specs_table",
        "content": "key-value pairs, e.g. Material, Dimensions, Weight Capacity, Compatibility"
      },
      {
        "block": "features_list",
        "content": "full bullet list of all features (not truncated like the card)"
      },
      {
        "block": "cta",
        "content": {
          "label": "Buy on Amazon",
          "style": "primary_button",
          "external_link": true
        }
      },
      {
        "block": "related_products",
        "content": "3-4 other products from the same category"
      }
    ]
  },

  "footer": {
    "columns": ["Company", "Products", "Support", "Legal"],
    "newsletter_signup": true,
    "social_links": ["Twitter/X", "Instagram", "LinkedIn"]
  }
